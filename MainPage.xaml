<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WEATHER_APP.MainPage"
             BackgroundColor="#101820">

 
    <ScrollView>


        <VerticalStackLayout Padding="20"
                             Spacing="20">


            <Label Text="Weather App"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>

    
            <Label Text="Enter a city name to see the weather"
                   FontSize="16"
                   TextColor="#CFCFCF"
                   HorizontalTextAlignment="Center"/>


            <Entry x:Name="CityEntry"
                   Placeholder="enter the city of name !"
                   PlaceholderColor="Gray"
                   TextColor="White"
                   BackgroundColor="#1E2A38"
                   HeightRequest="55"
                   FontSize="18"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0"/>

            <Button x:Name="SearchButton"
                    Text="SHOW RESULT"
                    HeightRequest="55"
                    FontSize="18"
                    CornerRadius="15"
                    BackgroundColor="#3A86FF"
                    TextColor="White"
                    Margin="0,10,0,20"
                    Clicked="SearchBtn"/>

          
            <Frame BackgroundColor="#1E2A38"
                   CornerRadius="20"
                   Padding="20"
                   HasShadow="True">

                
                <VerticalStackLayout Spacing="15">


                    <Label x:Name="CityText"
                           Text="City"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>


                    <Label x:Name="TempText"
                           Text="Temperature"
                           FontSize="24"
                           TextColor="#4CC9F0"
                           HorizontalTextAlignment="Center"/>


                    <Label x:Name="HumidityText"
                           Text="Humidity"
                           FontSize="20"
                           TextColor="#90E0EF"
                           HorizontalTextAlignment="Center"/>

                  
             
                  

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>